# Copy this file to .env and fill in your values. .env is gitignored.
#
# sandwich-detect and sandwich-eval auto-load .env via dotenvy on startup.

# Primary Solana RPC — used by the block scanner. Paid tier required for
# any multi-hour run; public endpoints will rate-limit hard.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# (Optional) RPC used for pool-account fetches during victim-loss enrichment.
# Defaults to RPC_URL. Point this at a dedicated / archival endpoint if you
# want to offload pool-state reads from the main scan endpoint.
# POOL_STATE_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# (Optional) Helius enhanced API key — only used by `sandwich-eval label` for
# pretty-printed tx details during hand-labeling.
# HELIUS_API_KEY=YOUR_KEY
